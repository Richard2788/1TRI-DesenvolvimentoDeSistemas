             "skipFiles": [
                 "<node_internals>/**"
            ]
         },
         {
            "name": "Launch Current Python File",
            "type": "debugpy",
             "request": "launch",
             "program": "${file}",
             "console": "integratedTerminal",
            "cwd": "${fileDirname}",
             "justMyCode": true
         }
    ]
 }